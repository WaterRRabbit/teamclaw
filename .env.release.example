# TeamClaw Release Environment Variables
# Copy this file to .env.release and fill in your actual values
# DO NOT commit .env.release to git (it's in .gitignore)

# =============================================================================
# Tauri Signing Key
# =============================================================================
# The private key used to sign your application updates
# 
# For PUBLIC version:
#   Use your public version private key
# 
# For INTERNAL version (seamless migration from old app):
#   Use the OLD application's private key
#   This ensures the update signature matches what users have installed
#
# To generate a new key pair (if needed):
#   tauri signer generate -w ~/.tauri/mykey.key
#
# IMPORTANT: Keep this key secure and never commit it to version control!
export TAURI_PRIVATE_KEY="xxxx"

# =============================================================================
# Backend URL (for internal version release only)
# =============================================================================
# The URL of your release backend API
# Only needed when uploading internal versions via scripts/release-to-backend.sh
#
# Examples:
#   - Local development: http://localhost:8888
#   - Production: https://releases.yourcompany.com
export BACKEND_URL="xxxx"

# =============================================================================
# Usage Examples
# =============================================================================
#
# 1. Public version (GitHub Releases):
#    - Edit build.config.json: set identifier to "com.teamclaw.app"
#    - Edit build.config.json: set updater.endpoint to GitHub URL
#    - export TAURI_PRIVATE_KEY="<your_public_version_key>"
#    - pnpm tauri:build
#    - Upload to GitHub Releases manually
#
# 2. Internal version (Backend API, seamless migration):
#    - Edit build.config.json: set identifier to OLD app identifier
#    - Edit build.config.json: set updater.endpoint to backend URL
#    - Edit build.config.json: set updater.pubkey to OLD app pubkey
#    - export TAURI_PRIVATE_KEY="<old_app_private_key>"
#    - export BACKEND_URL="http://localhost:8888"
#    - pnpm tauri:build
#    - ./scripts/release-to-backend.sh <version>
#
